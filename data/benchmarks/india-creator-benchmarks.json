  "category_caveats": [
    { "niche": "finance",   "note": "Finfluencers post-SEBI 2024 advisory rules require RA/RIA registration for stock-specific content; expect 20-40% premium for compliant creators. CTR is 2-3x lower than fashion but AOV (LTV proxy) is 5-10x higher. ROI must be measured on lifetime value, not first-purchase." },
    { "niche": "comedy",    "note": "Highest reach-per-rupee but lowest commercial intent. Best used for top-of-funnel awareness; do not benchmark against performance-marketing CPAs." },
    { "niche": "food",      "note": "Heavy barter culture in India - cash rates understate true compensation. Tier-2/3 food creators (regional cuisine) see disproportionately high engagement vs metro creators." },
    { "niche": "fashion",   "note": "Most saturated niche; rates compressed 15-20% in 2024-25 per Qoruz. Reels outperform static 4-6x in reach but have lower save-rates (a key conversion proxy)." },
    { "niche": "beauty",    "note": "Tutorial/demo content converts 2-3x better than aesthetic content. Tier-2 city creators driving D2C beauty growth (Mamaearth, Plum cohort)." },
    { "niche": "gaming",    "note": "BGMI/Free Fire creators have demographic skew to 14-22yr males, low purchasing power - good for app installs, weak for premium D2C. Live-stream rates are separate (typically per-hour, INR 5k-50k)." },
    { "niche": "tech",      "note": "YouTube long-form is the canonical format; IG reels under-perform for considered purchases. Affiliate-attributed conversions typically 3-5x higher than what brand sees in last-click." },
    { "niche": "education", "note": "Many edu creators are systematically under-priced relative to engagement. Edtech ad spend collapsed 40-60% post-Byju's; rates softened 2023-25." },
    { "niche": "travel",    "note": "Heavy in-kind component (hosted trips). Cash + hosting equivalent often 2x cash-only rate. Seasonal demand spikes (Oct-Mar, Apr-Jun) move rates 30%." },
    { "niche": "parenting", "note": "Highest trust/authority scores in India creator ecosystem per HypeAuditor; conversion rates strong but reach growth slow." },
    { "niche": "lifestyle", "note": "Catch-all bucket - sub-segment before benchmarking (home decor vs vlogger vs astrology have 5x rate spreads)." },
    { "niche": "fitness",   "note": "High personal-brand trust but supplement category faces repeat-FSSAI/ASCI scrutiny; conservative claims required." }
  ],

